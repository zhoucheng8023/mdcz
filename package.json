{
  "name": "mdcz",
  "version": "0.0.1",
  "description": "MDCz - media metadata scraper built on Electron",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "homepage": "https://github.com/ShotHeadman/mdcz",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShotHeadman/mdcz.git"
  },
  "author": {
    "name": "ShotHeadman",
    "email": "123543875+ShotHeadman@users.noreply.github.com"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "pnpm build && electron-builder --win",
    "build:mac": "pnpm build && electron-builder --mac",
    "build:linux": "pnpm build && electron-builder --linux AppImage",
    "test": "vitest run --silent",
    "test:main": "vitest run --project unit",
    "typecheck": "concurrently \"tsc --noEmit -p tsconfig.node.json\" \"tsc --noEmit -p tsconfig.web.json\"",
    "format": "biome check --write",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@egoist/tipc": "^0.3.2",
    "cheerio": "^1.2.0",
    "electron-window-state": "^5.0.3",
    "fast-xml-parser": "^5.3.0",
    "impit": "^0.9.2",
    "mediainfo.js": "^0.3.7",
    "openai": "^5.12.2",
    "opencc-js": "^1.0.5",
    "p-queue": "^9.0.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "impit-darwin-arm64": "0.9.2",
    "impit-darwin-x64": "0.9.2",
    "impit-linux-arm64-gnu": "0.9.2",
    "impit-linux-arm64-musl": "0.9.2",
    "impit-linux-x64-gnu": "0.9.2",
    "impit-linux-x64-musl": "0.9.2",
    "impit-win32-arm64-msvc": "0.9.2",
    "impit-win32-x64-msvc": "0.9.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@electron-toolkit/preload": "^3.0.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.159.4",
    "@tanstack/react-virtual": "^3.13.12",
    "@types/node": "^24.3.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.2.1",
    "electron": "^39.0.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "lint-staged": "^16.3.1",
    "lucide-react": "^0.563.0",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "react-resizable-panels": "^4.6.2",
    "simple-git-hooks": "^2.13.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0",
    "zustand": "^5.0.11"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "simple-git-hooks"
    ]
  }
}
